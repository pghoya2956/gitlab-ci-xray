{
  "name": "gitlab-ci-xray-core",
  "version": "0.3.0",
  "description": "GitLab CI pipeline analyzer core — parser, DAG, anti-pattern detection, optimization",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "tsx scripts/bundle-templates.ts && tsx scripts/bundle-schema.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
